# Required — get these from the respective dashboards
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Wake word — what you say to activate Proxy
PROXY_WAKE_PHRASE=proxy
PROXY_WAKE_ALIASES=proxy,roxy,rocky

# Stopword — what you say to interrupt a response
PROXY_STOPWORD_ALIASES=stop,shut up

# Voice tuning
PROXY_ELEVENLABS_MODEL_ID=eleven_v3
PROXY_ELEVENLABS_SPEED=1.0

# Speech-to-text
PROXY_DEEPGRAM_MODEL=nova-3
PROXY_DEEPGRAM_LANGUAGE=en-US
PROXY_DEEPGRAM_UTTERANCE_END_MS=3500
PROXY_DEEPGRAM_KEYTERMS=

# Listening behavior
PROXY_LISTENING_TIMEOUT_MS=10000

# Copilot
PROXY_COPILOT_COMMAND=copilot
PROXY_COPILOT_MODEL=

# Logging
PROXY_LOG_LEVEL=INFO

# Vanguard mode — local model for fillers and on-demand status (requires Ollama)
PROXY_VANGUARD_ENABLED=0
PROXY_VANGUARD_MODEL=llama3.2:3b
# PROXY_VANGUARD_CONTEXT=Projects: autograder, prisma-infrastructure, proxy. Languages: Python, Java.
# PROXY_STATUS_PHRASES=what's happening,status
# PROXY_COPILOT_PERSONA=casual and slightly witty
