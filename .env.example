# API credentials
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
TARS_ELEVENLABS_MODEL_ID=eleven_multilingual_v2
TARS_ELEVENLABS_OUTPUT_FORMAT=pcm_22050
TARS_ELEVENLABS_STABILITY=0.45
TARS_ELEVENLABS_SIMILARITY_BOOST=0.85
TARS_ELEVENLABS_STYLE=0.25
TARS_ELEVENLABS_SPEED=0.95
TARS_ELEVENLABS_USE_SPEAKER_BOOST=1
# Fallbacks used when primary format is denied by ElevenLabs plan/workspace permissions
TARS_ELEVENLABS_FALLBACK_OUTPUT_FORMATS=wav_22050,mp3_44100_128
# Runtime
TARS_LOG_LEVEL=INFO
TARS_QUEUE_MAXSIZE=256

# Audio I/O
TARS_AUDIO_SAMPLE_RATE=16000
TARS_AUDIO_CHANNELS=1
TARS_AUDIO_CHUNK_MS=20
TARS_AUDIO_INPUT_QUEUE_MAXSIZE=128
TARS_AUDIO_INPUT_DEVICE=
TARS_YES_ASSET_PATH=assets/yes.wav
TARS_WAKE_SOUNDS_DIR=assets/wake

# Wake word + VAD
TARS_WAKE_PHRASE=tars
TARS_WAKE_ALIASES=tars,stars,tarz
TARS_VOSK_MODEL_PATH=assets/models/vosk-model-small-en-us-0.15
TARS_VAD_START_RMS=600.0
TARS_VAD_END_RMS=350.0
TARS_VAD_END_SILENCE_MS=700
TARS_WAKE_DEBUG_TRANSCRIPTS=0
TARS_WAKE_DEBUG_RMS=0
TARS_WAKE_RETRIGGER_COOLDOWN_MS=1500
TARS_WAKE_REARM_GUARD_MS=1200
TARS_WAKE_MATCH_PARTIAL=0

# Deepgram STT
TARS_DEEPGRAM_MODEL=nova-3
TARS_DEEPGRAM_LANGUAGE=en-US
TARS_DEEPGRAM_ENDPOINTING_ENABLED=1
TARS_DEEPGRAM_ENDPOINTING_MS=700
TARS_DEEPGRAM_UTTERANCE_END_MS=3500
TARS_DEEPGRAM_PUNCTUATE=1
TARS_DEEPGRAM_SMART_FORMAT=1
TARS_DEEPGRAM_KEYTERMS=prisma-infrastructure,api-grader-prisma,app-grader-prisma,autograder,prisma backend,prisma frontend,pull request,draft PR,GitHub issue
TARS_DEEPGRAM_INTERIM_RESULTS=1
TARS_DEEPGRAM_RECONNECT_MAX_ATTEMPTS=3
TARS_DEEPGRAM_RECONNECT_BASE_DELAY_MS=200

# Speech turn controls
TARS_STT_GATE_ENABLED=1
TARS_STT_GATE_HOLD_MS=900
TARS_STT_DEECHO_ENABLED=1
TARS_STT_DEECHO_SIMILARITY_THRESHOLD=0.78
TARS_LISTENING_TIMEOUT_MS=10000
TARS_CANCEL_COMMANDS=nevermind,never mind,quit

# Copilot bridge
TARS_COPILOT_COMMAND=copilot
TARS_COPILOT_MODEL=
TARS_COPILOT_ALLOW_ALL=1
TARS_COPILOT_BOOTSTRAP_INSTRUCTIONS=1
TARS_COPILOT_INSTRUCTIONS_PATH=~/.copilot/copilot-instructions.md
TARS_COPILOT_ENABLE_FINAL_CONTRACT=1

# Assistant speech output
TARS_TTS_SPEAK_PARTIALS=1
