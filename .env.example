# API credentials
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
PROXY_ELEVENLABS_MODEL_ID=eleven_multilingual_v2
PROXY_ELEVENLABS_OUTPUT_FORMAT=pcm_22050
PROXY_ELEVENLABS_STABILITY=0.45
PROXY_ELEVENLABS_SIMILARITY_BOOST=0.85
PROXY_ELEVENLABS_STYLE=0.25
PROXY_ELEVENLABS_SPEED=0.95
PROXY_ELEVENLABS_USE_SPEAKER_BOOST=1
# Fallbacks used when primary format is denied by ElevenLabs plan/workspace permissions
PROXY_ELEVENLABS_FALLBACK_OUTPUT_FORMATS=wav_22050,mp3_44100_128
# Runtime
PROXY_LOG_LEVEL=INFO
PROXY_QUEUE_MAXSIZE=256

# Audio I/O
PROXY_AUDIO_SAMPLE_RATE=16000
PROXY_AUDIO_CHANNELS=1
PROXY_AUDIO_CHUNK_MS=20
PROXY_AUDIO_INPUT_QUEUE_MAXSIZE=128
PROXY_AUDIO_INPUT_DEVICE=
PROXY_YES_ASSET_PATH=assets/yes.wav
PROXY_WAKE_SOUNDS_DIR=assets/wake

# Wake word + VAD
PROXY_WAKE_PHRASE=proxy
PROXY_WAKE_ALIASES=proxy,stars,tarz
PROXY_VOSK_MODEL_PATH=assets/models/vosk-model-small-en-us-0.15
PROXY_VAD_START_RMS=600.0
PROXY_VAD_END_RMS=350.0
PROXY_VAD_END_SILENCE_MS=700
PROXY_WAKE_DEBUG_TRANSCRIPTS=0
PROXY_WAKE_DEBUG_RMS=0
PROXY_WAKE_RETRIGGER_COOLDOWN_MS=1500
PROXY_WAKE_REARM_GUARD_MS=1200
PROXY_WAKE_MATCH_PARTIAL=0

# Deepgram STT
PROXY_DEEPGRAM_MODEL=nova-3
PROXY_DEEPGRAM_LANGUAGE=en-US
PROXY_DEEPGRAM_ENDPOINTING_ENABLED=1
PROXY_DEEPGRAM_ENDPOINTING_MS=700
PROXY_DEEPGRAM_UTTERANCE_END_MS=3500
PROXY_DEEPGRAM_PUNCTUATE=1
PROXY_DEEPGRAM_SMART_FORMAT=1
PROXY_DEEPGRAM_KEYTERMS=prisma-infrastructure,api-grader-prisma,app-grader-prisma,autograder,prisma backend,prisma frontend,pull request,draft PR,GitHub issue
PROXY_DEEPGRAM_INTERIM_RESULTS=1
PROXY_DEEPGRAM_RECONNECT_MAX_ATTEMPTS=3
PROXY_DEEPGRAM_RECONNECT_BASE_DELAY_MS=200

# Speech turn controls
PROXY_STT_GATE_ENABLED=1
PROXY_STT_GATE_HOLD_MS=900
PROXY_STT_DEECHO_ENABLED=1
PROXY_STT_DEECHO_SIMILARITY_THRESHOLD=0.78
PROXY_LISTENING_TIMEOUT_MS=10000
PROXY_CANCEL_COMMANDS=nevermind,never mind,quit

# Copilot bridge
PROXY_COPILOT_COMMAND=copilot
PROXY_COPILOT_MODEL=
PROXY_COPILOT_ALLOW_ALL=1
PROXY_COPILOT_INSTRUCTIONS_PATH=~/.copilot/copilot-instructions.md

# Assistant speech output
PROXY_TTS_SPEAK_PARTIALS=1
PROXY_TTS_PARTIAL_MIN_CHARS=12
PROXY_TTS_PARTIAL_FORCE_FLUSH_CHARS=72
